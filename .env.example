# Copy to .env and fill values for local runs. NEVER commit real keys.

# --- Optional Groq key pool (PRD §10.5) ---------------------------------------
# Comma-separated list of keys. Order is preserved; runtime truncates to first 8.
# Aliases (e.g. key#1, key#2) are used in logs/audit; values are never persisted.
# Example:
# GROQ_API_KEYS=gsk_replace_me_1,gsk_replace_me_2
GROQ_API_KEYS=

# Legacy single-key fallback (used only if GROQ_API_KEYS is empty).
# GROQ_API_KEY=gsk_replace_me
GROQ_API_KEY=

# Model to call via Groq. Free tier default.
GROQ_MODEL=llama-3.3-70b-versatile

# Per-attempt hard timeout in seconds (calibrated for 70B model on free tier).
GROQ_TIMEOUT_S=3.5

# --- Local audit DB (PRD §11) --------------------------------------------------
# Defaults to ./data/auditor.db when unset.
AUDIT_DB_PATH=./data/auditor.db

# --- Server --------------------------------------------------------------------
HOST=0.0.0.0
PORT=8080